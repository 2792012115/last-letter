page {
  background: #faf8f5;
  font-family: -apple-system, "PingFang SC", "Noto Serif TC", serif;
  color: #2c2416;
  line-height: 1.8;
}

.container {
  padding: 32rpx 40rpx 80rpx;
}

/* 头部 */
.header {
  text-align: center;
  padding: 80rpx 0 60rpx;
}
.header .icon {
  font-size: 96rpx;
  display: block;
  margin-bottom: 24rpx;
}
.header .title {
  font-size: 44rpx;
  font-weight: 400;
  letter-spacing: 4rpx;
  color: #8b5e3c;
}
.header .subtitle {
  font-size: 26rpx;
  color: #8b7355;
  margin-top: 16rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 48rpx rgba(44,36,22,0.06);
  border: 1rpx solid #e8ddd0;
}

/* 关系选择 */
.rel-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.rel-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
  border: 2rpx solid #e8ddd0;
  border-radius: 20rpx;
  background: #fff;
  font-size: 30rpx;
  color: #2c2416;
  width: calc(50% - 10rpx);
  box-sizing: border-box;
}
.rel-btn.active {
  border-color: #8b5e3c;
  background: #faf3eb;
}
.rel-btn .rel-icon {
  font-size: 48rpx;
}

/* 输入框 */
.input-box {
  width: 100%;
  padding: 24rpx 28rpx;
  border: 2rpx solid #e8ddd0;
  border-radius: 20rpx;
  font-size: 30rpx;
  background: #fdfbf8;
  color: #2c2416;
  box-sizing: border-box;
  margin-top: 24rpx;
}

/* 按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 28rpx;
  border: none;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  background: linear-gradient(135deg, #c4956a, #b07d52);
  box-shadow: 0 8rpx 28rpx rgba(180,120,60,0.3);
  margin-top: 32rpx;
}
.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border: 2rpx solid #e8ddd0;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #8b5e3c;
  background: #fff;
}

/* 步骤指示器 */
.steps {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 36rpx;
  font-size: 24rpx;
  color: #8b7355;
}
.steps .step {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.steps .step-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #e8ddd0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #8b7355;
}
.steps .step.active .step-num {
  background: #8b5e3c;
  color: #fff;
}
.steps .step.done .step-num {
  background: #8fbc8f;
  color: #fff;
}
.steps .arrow {
  color: #e8ddd0;
}

/* 问题 */
.q-block {
  margin-bottom: 40rpx;
}
.q-block .q-label {
  font-size: 22rpx;
  color: #8b7355;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
}
.q-block .q-text {
  font-size: 30rpx;
  padding: 24rpx;
  background: #fdf8f4;
  border-radius: 16rpx;
  border-left: 6rpx solid #c4956a;
  margin-bottom: 20rpx;
}
.q-block .q-input {
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx;
  border: 2rpx solid #e8ddd0;
  border-radius: 16rpx;
  font-size: 28rpx;
  background: #fdfbf8;
  box-sizing: border-box;
}

/* 加载动画 */
.loading {
  text-align: center;
  padding: 80rpx 0;
}
.dots {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.dots view {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #c4956a;
  animation: bounce 1.4s infinite ease-in-out;
}
.dots view:nth-child(1) { animation-delay: 0s; }
.dots view:nth-child(2) { animation-delay: 0.2s; }
.dots view:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* 信件 */
.letter-paper {
  background: #fefdf9;
  border: 1rpx solid #e8ddd0;
  border-radius: 12rpx;
  padding: 48rpx 40rpx;
  margin: 32rpx 0;
  line-height: 2.2;
  font-size: 30rpx;
  white-space: pre-wrap;
  position: relative;
}
.letter-paper::before {
  content: '';
  position: absolute;
  top: 0;
  left: 60rpx;
  width: 2rpx;
  height: 100%;
  background: rgba(139,94,60,0.08);
}

/* 关键词 */
.keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 24rpx 0;
}
.keywords text {
  padding: 12rpx 24rpx;
  background: #fdf8f4;
  border: 1rpx solid #e8ddd0;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #8b5e3c;
}

/* 底部 */
.watermark {
  text-align: center;
  font-size: 22rpx;
  color: #8b7355;
  margin-top: 40rpx;
  padding-top: 28rpx;
  border-top: 2rpx dashed #e8ddd0;
}

/* 按钮行 */
.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}
.btn-row .btn-secondary { flex: 1; }
.btn-row .btn-primary { flex: 1; margin-top: 0; }
